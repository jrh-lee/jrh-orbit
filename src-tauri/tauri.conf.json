{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JRH-Orbit",
  "version": "0.4.5",
  "identifier": "com.jrh.orbit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "JRH-Orbit",
        "width": 1400,
        "height": 860,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:orbit.db"]
    },
    "fs": {}
  }
}
